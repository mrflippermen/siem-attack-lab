# =========================================================
#  Variables del laboratorio SIEM + Ataque  (PLANTILLA)
#  Copia este fichero a .env y ajusta los valores:
#      cp .env.example .env
#  El .env real NO se versiona (esta en .gitignore).
# =========================================================
COMPOSE_PROJECT_NAME=siemlab

# --- Stack ELK ---
ELK_VERSION=8.13.4
ES_JAVA_MEM=1g

# --- Base de datos del target vulnerable ---
# Cambia estas contraseñas por las tuyas (cualquier valor sirve en el lab).
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=change-me-app

# --- Credencial "secreta" del backend que se exfiltra en el ataque ---
# (vive en la tabla users, es el objetivo de la inyeccion SQL)
ADMIN_USER=admin
ADMIN_SECRET=change-me-secret
