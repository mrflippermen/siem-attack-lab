{
  "index_patterns": ["weblogs-*"],
  "priority": 200,
  "template": {
    "settings": {
      "number_of_replicas": 0,
      "number_of_shards": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "clientip":   { "type": "ip" },
        "response":   { "type": "integer" },
        "bytes":      { "type": "long" },
        "verb":       { "type": "keyword" },
        "request":    { "type": "wildcard" },
        "httpversion":{ "type": "keyword" },
        "agent":      { "type": "keyword" },
        "referrer":   { "type": "keyword" },
        "log_type":   { "type": "keyword" },
        "tags":       { "type": "keyword" },
        "level":      { "type": "keyword" },
        "ua": {
          "properties": {
            "name":    { "type": "keyword" },
            "version": { "type": "keyword" },
            "os":      { "type": "keyword" },
            "os_name": { "type": "keyword" },
            "os_full": { "type": "keyword" },
            "major":   { "type": "keyword" },
            "minor":   { "type": "keyword" },
            "patch":   { "type": "keyword" },
            "device":  { "type": "keyword" }
          }
        },
        "geo": {
          "properties": {
            "location":     { "type": "geo_point" },
            "country_name": { "type": "keyword" },
            "city_name":    { "type": "keyword" }
          }
        }
      }
    }
  }
}
